<!DOCTYPE html>
{#
  Shiftora sample-site template.

  Reads the REAL business data we scraped plus any researched enrichment the
  renderer injected: brand-derived palette, business-specific copy
  (headline / hero_sub / about_paras / service_cards / highlights),
  real reviews, and real photos (logo_url / hero_url). EVERY optional variable
  is guarded so the page is always complete and beautiful even with none of it.

  Honesty by design: NO fabricated star ratings or "loved by locals" badges —
  the reviews section only appears when we actually found real reviews. The
  "free sample built by Shiftora" note lives quietly in the footer, so the page
  reads as the business's own first.

  Self-contained: one inline <style>, no web fonts, no <link>/@import. The only
  external src is an optional researched photo (logo/hero). JS is progressive
  enhancement only.
#}
{%- set t = theme if theme else {} -%}
{%- set accent      = t.accent      if t.accent      else '#c9893f' -%}
{%- set accent_dark = t.accent_dark if t.accent_dark else '#a96f2c' -%}
{%- set ink         = t.ink         if t.ink         else '#2a211a' -%}
{%- set soft        = t.soft        if t.soft        else '#f7f3ee' -%}
{%- set hero_from   = t.hero_from   if t.hero_from   else '#2a211a' -%}
{%- set hero_to     = t.hero_to     if t.hero_to     else '#3a2c1f' -%}
{%- set place = [] -%}
{%- if biz.city %}{% set _ = place.append(biz.city) %}{% endif -%}
{%- if biz.country %}{% set _ = place.append(biz.country) %}{% endif -%}
{%- set locale = place | join(', ') -%}
{%- set headline = headline if headline else biz.name -%}
{%- set category = biz.category if biz.category else 'local favourite' -%}
{%- set headline_is_name = (headline | trim | lower) == (biz.name | trim | lower) -%}
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ biz.name }}{% if biz.city %} — {{ biz.city }}{% endif %}{% if biz.category %} · {{ biz.category }}{% endif %}</title>
<meta name="description" content="{% if hero_sub %}{{ hero_sub }}{% elif biz.description %}{{ biz.description }}{% else %}{{ biz.name }} — {{ category }}{% if biz.city %} in {{ biz.city }}{% endif %}.{% endif %}">
<meta name="theme-color" content="{{ accent }}">
<style>
  :root{
    --accent:{{ accent }};
    --accent-dark:{{ accent_dark }};
    --ink:{{ ink }};
    --soft:{{ soft }};
    --hero-from:{{ hero_from }};
    --hero-to:{{ hero_to }};

    --paper:#fffdfb;
    --cream:color-mix(in srgb, var(--soft) 78%, #ffffff);
    --muted:color-mix(in srgb, var(--ink) 56%, #ffffff);
    --line:color-mix(in srgb, var(--ink) 13%, #ffffff);
    --on-hero:#fff;
    --on-hero-soft:color-mix(in srgb, #fff 78%, var(--accent));
    --max:1120px;
    --r:22px;
    --shadow:0 22px 60px -28px color-mix(in srgb, var(--ink) 55%, transparent);
    --shadow-sm:0 10px 28px -16px color-mix(in srgb, var(--ink) 55%, transparent);
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
  body{
    margin:0;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    color:var(--ink);background:var(--paper);line-height:1.65;
    -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
  }
  a{color:var(--accent-dark);text-decoration:none}
  img{max-width:100%;display:block}
  .wrap{max-width:var(--max);margin:0 auto;padding:0 22px;width:100%}
  .eyebrow{
    text-transform:uppercase;letter-spacing:.2em;font-size:12.5px;font-weight:700;
    color:var(--accent-dark);margin:0 0 14px;display:flex;align-items:center;gap:10px;
  }
  .eyebrow::before{content:"";width:26px;height:2px;border-radius:2px;background:var(--accent)}
  h1,h2,h3{letter-spacing:-.02em;line-height:1.1;margin-top:0}

  /* ---- nav ---- */
  header{position:sticky;top:0;z-index:50}
  nav{
    display:flex;align-items:center;justify-content:space-between;gap:16px;padding:13px 0;
    background:color-mix(in srgb, var(--paper) 84%, transparent);
    backdrop-filter:saturate(160%) blur(12px);-webkit-backdrop-filter:saturate(160%) blur(12px);
    border-bottom:1px solid transparent;transition:border-color .3s, box-shadow .3s;
  }
  nav.scrolled{border-color:var(--line);box-shadow:0 8px 26px -22px color-mix(in srgb, var(--ink) 70%, transparent)}
  .brand{display:flex;align-items:center;gap:12px;min-width:0}
  .mark{
    width:44px;height:44px;border-radius:15px;flex:0 0 auto;display:grid;place-items:center;
    color:#fff;font-weight:800;font-size:20px;overflow:hidden;
    background:linear-gradient(145deg,var(--accent),var(--accent-dark));box-shadow:var(--shadow-sm);
  }
  .mark img{width:100%;height:100%;object-fit:cover}
  .brand-text{display:flex;flex-direction:column;min-width:0}
  .brand-name{font-weight:800;font-size:18px;line-height:1.15;letter-spacing:-.01em;
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--ink)}
  .brand-sub{font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--muted)}
  .nav-cta{
    background:var(--accent);color:#fff;padding:11px 22px;border-radius:999px;
    font-weight:700;font-size:14.5px;white-space:nowrap;box-shadow:var(--shadow-sm);
    transition:transform .15s, background .2s;
  }
  .nav-cta:hover{transform:translateY(-1px);background:var(--accent-dark)}

  /* ---- hero ---- */
  .hero{
    position:relative;overflow:hidden;color:var(--on-hero);
    background:
      radial-gradient(130% 95% at 86% -12%, color-mix(in srgb, var(--accent) 60%, transparent), transparent 58%),
      radial-gradient(90% 80% at -6% 112%, color-mix(in srgb, var(--accent-dark) 48%, transparent), transparent 55%),
      linear-gradient(165deg, var(--hero-from) 0%, var(--hero-to) 100%);
  }
  .hero::before,.hero::after{content:"";position:absolute;border-radius:50%;z-index:0;filter:blur(2px)}
  .hero::before{width:360px;height:360px;top:-100px;right:-70px;opacity:.35;
    background:radial-gradient(circle at 35% 35%, var(--accent), transparent 70%)}
  .hero::after{width:280px;height:280px;bottom:-130px;left:-60px;opacity:.3;
    background:radial-gradient(circle at 50% 50%, var(--accent-dark), transparent 70%)}
  .hero-inner{
    position:relative;z-index:1;display:grid;grid-template-columns:1.18fr .82fr;gap:48px;
    align-items:center;padding:78px 0 86px;
  }
  .hero .eyebrow{color:var(--on-hero-soft)}
  .hero .eyebrow::before{background:var(--accent)}
  .hero h1{font-size:clamp(38px,6.6vw,68px);font-weight:800;margin:0 0 20px;color:#fff}
  .h1-kicker{display:block;margin-top:12px;font-size:clamp(16px,2vw,21px);font-weight:600;
    letter-spacing:0;color:color-mix(in srgb,#fff 72%,var(--accent))}
  .hero-sub{font-size:clamp(17px,2.2vw,21px);color:color-mix(in srgb, #fff 86%, var(--accent));
    max-width:540px;margin:0 0 32px}
  .btns{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
  .btn{
    display:inline-flex;align-items:center;gap:9px;padding:15px 28px;border-radius:999px;
    font-weight:700;font-size:15.5px;transition:transform .15s, box-shadow .2s, background .2s, border-color .2s;cursor:pointer;
  }
  .btn-primary{background:var(--accent);color:#fff;box-shadow:0 16px 34px -14px color-mix(in srgb, var(--accent) 90%, transparent)}
  .btn-primary:hover{transform:translateY(-2px);background:var(--accent-dark)}
  .btn-ghost{background:color-mix(in srgb, #fff 14%, transparent);color:#fff;border:1.5px solid color-mix(in srgb,#fff 35%,transparent)}
  .btn-ghost:hover{transform:translateY(-2px);border-color:#fff;background:color-mix(in srgb,#fff 22%,transparent)}
  .trust{list-style:none;margin:30px 0 0;padding:0;display:flex;flex-wrap:wrap;gap:10px 22px}
  .trust li{display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;
    color:color-mix(in srgb,#fff 80%,var(--accent))}
  .trust li::before{content:"●";color:var(--accent);font-size:10px}

  /* hero showcase: a real photo if we have one, else a cosy CSS-only card */
  .hero-card{
    position:relative;border-radius:28px;overflow:hidden;min-height:300px;
    background:linear-gradient(160deg,#fff,var(--cream));
    border:1px solid color-mix(in srgb,#fff 70%,var(--accent));box-shadow:var(--shadow);
  }
  .hero-photo{min-height:340px;background-size:cover;background-position:center}
  .hero-card .awning{
    height:58px;
    background:repeating-linear-gradient(90deg,var(--accent) 0 28px,#fff 28px 56px);
    border-bottom:4px solid var(--accent-dark);
    -webkit-mask:radial-gradient(14px 18px at 14px 100%, transparent 96%, #000) repeat-x bottom/28px 18px;
    mask:radial-gradient(14px 18px at 14px 100%, transparent 96%, #000) repeat-x bottom/28px 18px;
  }
  /* alternate CSS art for variety (seed 1) */
  .hero-card.v1{background:
      radial-gradient(circle at 22% 20%, color-mix(in srgb,var(--accent) 38%,#fff), transparent 45%),
      radial-gradient(circle at 82% 78%, color-mix(in srgb,var(--accent-dark) 34%,#fff), transparent 48%),
      linear-gradient(150deg,#fff,var(--cream))}
  .hero-card.v2 .awning{background:repeating-linear-gradient(135deg,var(--accent) 0 18px,color-mix(in srgb,var(--accent) 30%,#fff) 18px 36px)}
  .hero-card .pane{padding:24px 26px 28px}
  .hero-card .chip{
    display:inline-block;background:var(--soft);color:var(--accent-dark);
    font-weight:700;font-size:13px;padding:7px 14px;border-radius:999px;margin:0 8px 8px 0;
  }
  .hero-card .openline{display:flex;align-items:center;gap:10px;margin-top:16px;font-weight:700;color:var(--ink)}
  .hero-card .pulse{width:11px;height:11px;border-radius:50%;background:#3aa76d;
    box-shadow:0 0 0 0 rgba(58,167,109,.5);animation:pulse 2.4s infinite}
  .hero-card .blurb{margin-top:14px;color:var(--muted);font-size:14.5px;line-height:1.5}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(58,167,109,.45)}70%{box-shadow:0 0 0 12px rgba(58,167,109,0)}100%{box-shadow:0 0 0 0 rgba(58,167,109,0)}}

  /* ---- generic section ---- */
  section{padding:80px 0}
  .sec-head{max-width:660px}
  h2{font-size:clamp(28px,4.2vw,42px);font-weight:800;margin:0 0 14px;color:var(--ink)}
  .lead{color:var(--muted);font-size:clamp(16px,2vw,18.5px);margin:0}

  /* ---- services ---- */
  .services{background:linear-gradient(180deg,var(--paper),var(--cream) 55%,var(--paper))}
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:22px;margin-top:42px}
  .card{
    background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:30px 28px;
    box-shadow:var(--shadow-sm);transition:transform .2s, box-shadow .2s, border-color .2s;
    position:relative;overflow:hidden;
  }
  .card::after{content:"";position:absolute;right:-40px;top:-40px;width:120px;height:120px;border-radius:50%;
    background:radial-gradient(circle, color-mix(in srgb, var(--accent) 18%, transparent), transparent 70%)}
  .card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:color-mix(in srgb, var(--accent) 45%, var(--line))}
  .ic{
    width:54px;height:54px;border-radius:16px;display:grid;place-items:center;margin-bottom:18px;
    background:linear-gradient(145deg, color-mix(in srgb, var(--accent) 24%, #fff), color-mix(in srgb, var(--accent) 9%, #fff));
    color:var(--accent-dark);font-weight:800;font-size:21px;position:relative;z-index:1;
  }
  .card .num{position:absolute;top:20px;right:24px;z-index:1;font-weight:800;font-size:15px;
    letter-spacing:.04em;color:color-mix(in srgb,var(--accent) 55%,var(--line))}
  .card h3{margin:0 0 8px;font-size:20px;font-weight:800;color:var(--ink);position:relative;z-index:1}
  .card p{margin:0;color:var(--muted);position:relative;z-index:1}

  /* ---- about ---- */
  .about-inner{display:grid;grid-template-columns:.92fr 1.08fr;gap:54px;align-items:center}
  .about-art{
    border-radius:26px;min-height:300px;position:relative;overflow:hidden;
    background:
      radial-gradient(circle at 28% 24%, color-mix(in srgb, var(--accent) 58%, #fff), transparent 46%),
      radial-gradient(circle at 80% 74%, color-mix(in srgb, var(--accent-dark) 52%, #fff), transparent 50%),
      linear-gradient(150deg, var(--soft), var(--cream));
    border:1px solid color-mix(in srgb, var(--ink) 9%, #fff);box-shadow:var(--shadow);
  }
  .about-art.photo{background-size:cover;background-position:center}
  .about-art .quote{
    position:absolute;inset:auto 22px 22px 22px;background:rgba(255,255,255,.9);
    backdrop-filter:blur(4px);border-radius:18px;padding:20px 22px;font-weight:600;color:var(--ink);
    box-shadow:var(--shadow-sm);
  }
  .about-art .quote span{display:block;margin-top:8px;font-weight:700;color:var(--accent-dark);font-size:14px}
  .about-text p{font-size:clamp(16px,1.9vw,18.5px);color:color-mix(in srgb, var(--ink) 80%, #fff);margin:0 0 18px}
  .pills{display:flex;flex-wrap:wrap;gap:10px;margin-top:6px}
  .pill{background:var(--soft);color:var(--accent-dark);font-weight:700;font-size:13.5px;padding:8px 16px;border-radius:999px}

  /* ---- reviews (only rendered when real reviews exist) ---- */
  .reviews{background:var(--soft)}
  .rev-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px;margin-top:42px}
  .rev{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:28px 28px 24px;box-shadow:var(--shadow-sm)}
  .rev .mark2{font-size:42px;line-height:.6;color:color-mix(in srgb,var(--accent) 55%,var(--line));font-family:Georgia,serif}
  .rev p{margin:8px 0 16px;color:var(--ink);font-size:16.5px}
  .rev .who{font-weight:700;color:var(--accent-dark);font-size:14px}
  .rev .who small{display:block;color:var(--muted);font-weight:600;font-size:12.5px;margin-top:2px}

  /* ---- hours ---- */
  .hours{background:var(--cream)}
  .hours-card{
    margin-top:36px;background:#fff;border:1px solid var(--line);border-radius:var(--r);
    box-shadow:var(--shadow-sm);overflow:hidden;max-width:580px;
  }
  .hours-row{display:flex;justify-content:space-between;align-items:center;gap:16px;
    padding:15px 26px;border-bottom:1px solid var(--line);font-size:16px}
  .hours-row:last-child{border-bottom:none}
  .hours-row .day{font-weight:700;color:var(--ink)}
  .hours-row .time{color:var(--muted);font-variant-numeric:tabular-nums;text-align:right}

  /* ---- contact ---- */
  .contact{background:linear-gradient(180deg,var(--paper),var(--cream))}
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:36px;margin-top:42px;align-items:stretch}
  .info{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:30px;box-shadow:var(--shadow-sm)}
  .info-item{display:flex;gap:14px;align-items:flex-start;padding:14px 0;border-bottom:1px solid var(--line)}
  .info-item:last-child{border-bottom:none}
  .info-item .ic2{flex:0 0 auto;width:42px;height:42px;border-radius:12px;display:grid;place-items:center;
    background:var(--soft);color:var(--accent-dark);font-size:18px}
  .info-item .k{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:700}
  .info-item .v{font-weight:600;color:var(--ink);word-break:break-word}
  .info-item .v a{color:var(--ink)}
  .info-item .v a:hover{color:var(--accent-dark)}
  .socials{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap}
  .social{display:inline-flex;align-items:center;gap:8px;background:var(--soft);color:var(--accent-dark);
    font-weight:700;font-size:14px;padding:10px 16px;border-radius:999px;transition:background .2s}
  .social:hover{background:color-mix(in srgb, var(--accent) 18%, var(--soft))}
  .map{
    position:relative;border-radius:var(--r);overflow:hidden;min-height:300px;border:1px solid var(--line);
    box-shadow:var(--shadow-sm);display:flex;align-items:flex-end;justify-content:center;padding:22px;
    background-color:var(--cream);
    background-image:
      linear-gradient(color-mix(in srgb, var(--ink) 7%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--ink) 7%, transparent) 1px, transparent 1px),
      radial-gradient(circle at 50% 42%, color-mix(in srgb, var(--accent) 30%, transparent), transparent 38%);
    background-size:34px 34px, 34px 34px, 100% 100%;
  }
  .map .pin{
    position:absolute;top:38%;left:50%;transform:translate(-50%,-100%) rotate(-45deg);
    width:30px;height:30px;border-radius:50% 50% 50% 0;
    background:linear-gradient(145deg,var(--accent),var(--accent-dark));
    box-shadow:0 10px 18px -8px color-mix(in srgb, var(--accent-dark) 80%, transparent);
  }
  .map .pin::after{content:"";position:absolute;inset:0;margin:auto;width:11px;height:11px;border-radius:50%;background:#fff}
  .map .maplink{position:relative;background:#fff;color:var(--ink);padding:11px 20px;border-radius:999px;font-weight:700;
    box-shadow:var(--shadow-sm);transition:transform .15s}
  .map .maplink:hover{transform:translateY(-2px);color:var(--accent-dark)}

  /* ---- menu / price list ---- */
  .menu{background:var(--paper)}
  .menu-groups{margin-top:38px;display:grid;gap:36px}
  @media(min-width:760px){.menu-groups.multi{grid-template-columns:1fr 1fr;gap:34px 60px}}
  .menu-group h3{font-weight:800;color:var(--accent-dark);margin:0 0 12px;
    text-transform:uppercase;letter-spacing:.09em;font-size:13.5px}
  .menu-list{display:grid;gap:0}
  .menu-item{display:flex;justify-content:space-between;align-items:baseline;gap:16px;
    padding:13px 0;border-bottom:1px dashed var(--line)}
  .menu-item:last-child{border-bottom:none}
  .menu-item .mi-main{min-width:0}
  .menu-item .mi-name{font-weight:700;color:var(--ink)}
  .menu-item .mi-desc{color:var(--muted);font-size:14.5px;margin-top:2px;line-height:1.5}
  .menu-item .mi-price{font-weight:800;color:var(--accent-dark);white-space:nowrap;font-variant-numeric:tabular-nums}
  .menu-note{margin-top:24px;color:var(--muted);font-size:14.5px;font-style:italic}

  /* ---- steps / how it works ---- */
  .steps-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:22px;margin-top:42px}
  .step{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:28px 26px;box-shadow:var(--shadow-sm)}
  .step .step-n{width:40px;height:40px;border-radius:12px;display:grid;place-items:center;font-weight:800;font-size:17px;
    background:linear-gradient(145deg,var(--accent),var(--accent-dark));color:#fff;margin-bottom:16px}
  .step h3{margin:0 0 6px;font-size:18px;font-weight:800;color:var(--ink)}
  .step p{margin:0;color:var(--muted)}

  /* ---- good to know ---- */
  .gtk{background:var(--soft)}
  .gtk-wrap{display:flex;flex-wrap:wrap;gap:12px;margin-top:6px}
  .gtk-chip{display:inline-flex;align-items:center;gap:9px;background:#fff;border:1px solid var(--line);
    border-radius:999px;padding:11px 18px;font-weight:600;color:var(--ink);box-shadow:var(--shadow-sm)}
  .gtk-chip::before{content:"✓";color:var(--accent-dark);font-weight:800}

  /* ---- cta band ---- */
  .cta-band{background:linear-gradient(150deg,var(--hero-from),var(--hero-to));color:#fff;position:relative;overflow:hidden}
  .cta-band::before{content:"";position:absolute;width:320px;height:320px;border-radius:50%;top:-120px;right:-60px;opacity:.3;
    background:radial-gradient(circle,var(--accent),transparent 70%)}
  .cta-band .wrap{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:24px;position:relative;z-index:1}
  .cta-band h2{color:#fff;margin:0}
  .cta-band p{margin:10px 0 0;color:color-mix(in srgb,#fff 82%,var(--accent));max-width:520px}
  .cta-band .btn-primary{background:var(--accent);color:#fff}
  .cta-band .btn-primary:hover{background:#fff;color:var(--ink)}

  /* ---- footer ---- */
  footer{background:var(--ink);color:color-mix(in srgb,#fff 76%,var(--ink));padding:54px 0 40px}
  .foot-grid{display:flex;flex-wrap:wrap;gap:28px;justify-content:space-between;align-items:center}
  .foot-brand{font-weight:800;font-size:20px;color:#fff}
  .foot-cta{display:inline-flex;align-items:center;gap:9px;background:var(--accent);color:#fff;padding:14px 26px;
    border-radius:999px;font-weight:700;box-shadow:0 16px 34px -16px color-mix(in srgb, var(--accent) 95%, transparent);
    transition:transform .15s, background .2s}
  .foot-cta:hover{transform:translateY(-2px);background:var(--accent-dark)}
  .foot-meta{margin-top:30px;padding-top:22px;border-top:1px solid color-mix(in srgb,#fff 16%,var(--ink));font-size:14px;
    display:flex;flex-wrap:wrap;gap:8px 18px;justify-content:space-between;color:color-mix(in srgb,#fff 60%,var(--ink))}
  .foot-meta a{color:#fff;font-weight:600}
  .sample-badge{display:inline-flex;align-items:center;gap:7px;font-size:12.5px;
    color:color-mix(in srgb,#fff 55%,var(--ink))}
  .sample-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}

  /* ---- mobile sticky CTA ---- */
  .sticky-cta{
    position:fixed;left:14px;right:14px;bottom:14px;z-index:70;display:none;
    align-items:center;justify-content:space-between;gap:12px;
    background:var(--ink);color:#fff;padding:12px 14px 12px 18px;border-radius:18px;
    box-shadow:0 18px 40px -12px rgba(0,0,0,.5);transform:translateY(150%);transition:transform .35s ease;
  }
  .sticky-cta.show{transform:translateY(0)}
  .sticky-cta .t{font-weight:700;font-size:14px;line-height:1.2}
  .sticky-cta .t small{display:block;font-weight:500;font-size:12px;color:color-mix(in srgb,#fff 70%,var(--ink))}
  .sticky-cta a{background:var(--accent);color:#fff;padding:11px 18px;border-radius:999px;font-weight:700;font-size:14px;white-space:nowrap}

  /* ---- responsive ---- */
  @media(max-width:880px){
    .hero-inner{grid-template-columns:1fr;gap:34px;padding:56px 0 66px}
    .hero-card{order:-1;min-height:230px}
    .about-inner{grid-template-columns:1fr;gap:32px}
    .about-art{min-height:230px;order:-1}
    .contact-grid{grid-template-columns:1fr}
    .map{min-height:230px}
  }
  @media(max-width:640px){
    section{padding:58px 0}
    .nav-cta{display:none}
    .sticky-cta{display:flex}
    .foot-grid{flex-direction:column;align-items:flex-start;gap:18px}
  }
  @media(prefers-reduced-motion:reduce){
    *{animation:none!important;scroll-behavior:auto!important;transition:none!important}
  }
</style>
</head>
<body>

{# ---------- NAV ---------- #}
<header>
  <div class="wrap">
    <nav id="nav">
      <div class="brand">
        <div class="mark" aria-hidden="true">
          {%- if logo_url %}<img src="{{ logo_url }}" alt="{{ biz.name }} logo">
          {%- else %}{{ biz.name[0]|upper if biz.name else '•' }}{% endif -%}
        </div>
        <div class="brand-text">
          <span class="brand-name">{{ biz.name }}</span>
          {% if biz.category or biz.city %}
          <span class="brand-sub">{{ biz.category }}{% if biz.category and biz.city %} · {% endif %}{{ biz.city }}</span>
          {% endif %}
        </div>
      </div>
      <a class="nav-cta" href="#contact">{% if biz.phone %}Call us{% else %}Contact{% endif %}</a>
    </nav>
  </div>
</header>

{# ---------- HERO ---------- #}
<div class="hero">
  <div class="wrap">
    <div class="hero-inner">
      <div class="hero-copy">
        {% if locale %}
        <p class="eyebrow">{{ locale }}</p>
        {% elif biz.category %}
        <p class="eyebrow">Your local {{ biz.category }}</p>
        {% endif %}

        <h1>{{ headline }}{% if headline_is_name %}<span class="h1-kicker">{% if hero_kicker %}{{ hero_kicker }}{% elif biz.category %}Your {{ biz.category }}{% if biz.city %} in {{ biz.city }}{% endif %}{% elif biz.city %}A local favourite in {{ biz.city }}{% else %}A local favourite, done right{% endif %}</span>{% endif %}</h1>

        <p class="hero-sub">
          {%- if hero_sub %}{{ hero_sub }}
          {%- else %}Welcome to {{ biz.name }}{% if biz.category %}, your friendly {{ biz.category }}{% endif %}{% if biz.city %} in the heart of {{ biz.city }}{% endif %}. We'd love to see you soon.{% endif %}
        </p>

        <div class="btns">
          <a class="btn btn-primary" href="{{ cta.href }}">{{ cta.label }} →</a>
          {% if 'tel:' in cta.href %}
          <a class="btn btn-ghost" href="#contact">See what we offer →</a>
          {% elif biz.phone %}
          <a class="btn btn-ghost" href="tel:{{ biz.phone }}">📞 Call us</a>
          {% endif %}
        </div>

        {% if highlights %}
        <ul class="trust" aria-label="Highlights">
          {% for h in highlights %}<li><span>{{ h }}</span></li>{% endfor %}
        </ul>
        {% endif %}
      </div>

      {# showcase: real photo if researched, else a varied CSS-only card #}
      {% if hero_url %}
      <div class="hero-card hero-photo" style="background-image:url('{{ hero_url }}')" role="img" aria-label="{{ biz.name }}"></div>
      {% else %}
      <div class="hero-card v{{ visual_seed }}" aria-hidden="true">
        {% if visual_seed != 1 %}<div class="awning"></div>{% endif %}
        <div class="pane">
          {% if service_cards %}
            {% for s in service_cards[:3] %}<span class="chip">{{ s.title }}</span>{% endfor %}
          {% elif biz.cuisine %}
            {% for c in biz.cuisine.split(',') %}<span class="chip">{{ c|trim|title }}</span>{% endfor %}
          {% else %}
            <span class="chip">Warm welcome</span><span class="chip">Local favourite</span>
          {% endif %}
          <div class="openline"><span class="pulse"></span> {% if hours %}Open this week{% else %}Open &amp; ready to welcome you{% endif %}</div>
          {% if biz.address %}<div class="blurb">{{ biz.address }}</div>{% endif %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{# ---------- SERVICES ---------- #}
{% if service_cards %}
<section class="services">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">What we offer</p>
      <h2>{% if biz.category %}Everything {{ biz.name }} does best{% else %}What brings people in{% endif %}</h2>
      <p class="lead">A little taste of what brings people back to {{ biz.name }}{% if biz.city %} in {{ biz.city }}{% endif %}.</p>
    </div>
    <div class="grid">
      {% for s in service_cards %}
      <div class="card">
        <span class="num" aria-hidden="true">{{ '%02d'|format(loop.index) }}</span>
        <div class="ic" aria-hidden="true">{{ s.title[0]|upper }}</div>
        <h3>{{ s.title }}</h3>
        <p>{{ s.blurb }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ---------- MENU / PRICE LIST (only when researched) ---------- #}
{% if menu %}
<section class="menu">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">{% if biz.category in ['café','bakery','restaurant','eatery','bar','pub','deli','ice cream shop'] %}Menu &amp; prices{% else %}Services &amp; prices{% endif %}</p>
      <h2>{{ menu.title }}</h2>
    </div>
    <div class="menu-groups{% if menu.groups|length > 1 %} multi{% endif %}">
      {% for g in menu.groups %}
      <div class="menu-group">
        {% if g.name %}<h3>{{ g.name }}</h3>{% endif %}
        <div class="menu-list">
          {% for it in g['items'] %}
          <div class="menu-item">
            <div class="mi-main">
              <div class="mi-name">{{ it.name }}</div>
              {% if it.desc %}<div class="mi-desc">{{ it.desc }}</div>{% endif %}
            </div>
            {% if it.price %}<div class="mi-price">{{ it.price }}</div>{% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% if menu.note %}<p class="menu-note">{{ menu.note }}</p>{% endif %}
  </div>
</section>
{% endif %}

{# ---------- HOW IT WORKS / STEPS (only when researched) ---------- #}
{% if steps %}
<section class="about">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">How it works</p>
      <h2>{{ steps.title }}</h2>
    </div>
    <div class="steps-grid">
      {% for it in steps['items'] %}
      <div class="step">
        <div class="step-n" aria-hidden="true">{{ loop.index }}</div>
        <h3>{{ it.title }}</h3>
        {% if it.desc %}<p>{{ it.desc }}</p>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ---------- ABOUT ---------- #}
<section class="about">
  <div class="wrap">
    <div class="about-inner">
      <div class="about-art{% if hero_url %} photo{% endif %}" {% if hero_url %}style="background-image:url('{{ hero_url }}')"{% endif %} aria-hidden="true">
        {% if reviews and reviews[0] %}
        <div class="quote">
          &ldquo;{{ reviews[0].text|truncate(120, true, '…') }}&rdquo;
          <span>— {{ reviews[0].author or 'a happy customer' }}</span>
        </div>
        {% elif not hero_url %}
        <div class="quote">
          &ldquo;{% if biz.city %}A real {{ biz.city }} gem.{% else %}Somewhere that feels like home.{% endif %}&rdquo;
          <span>— what people say about {{ biz.name }}</span>
        </div>
        {% endif %}
      </div>
      <div class="about-text">
        <p class="eyebrow">Our story</p>
        <h2>{{ story_heading if story_heading else 'A warm welcome, every time' }}</h2>
        {% if about_paras %}
          {% for p in about_paras %}<p>{{ p }}</p>{% endfor %}
        {% elif biz.description %}
        <p>{{ biz.description }}</p>
        <p>Whether you're a regular or stopping by for the first time, there's always a friendly face waiting at {{ biz.name }}.</p>
        {% else %}
        <p>{{ biz.name }} is{% if biz.city %} a much-loved {{ category }} in {{ biz.city }}{% else %} a much-loved local {{ category }}{% endif %}, built on the simple things done well: genuine care, real quality, and the kind of welcome that makes you want to come back.</p>
        <p>Every detail — from the moment you arrive to the moment you leave — is here to make you feel right at home.</p>
        {% endif %}
        <div class="pills">
          {% if service_cards %}
            {% for s in service_cards[:4] %}<span class="pill">{{ s.title }}</span>{% endfor %}
          {% else %}
            <span class="pill">Friendly faces</span>
            <span class="pill">Local &amp; loved</span>
            {% if biz.city %}<span class="pill">Proudly {{ biz.city }}</span>{% endif %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{# ---------- REVIEWS (only when we found real ones) ---------- #}
{% if reviews %}
<section class="reviews">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">In their words</p>
      <h2>What customers say</h2>
      <p class="lead">A few words from people who've been in.</p>
    </div>
    <div class="rev-grid">
      {% for r in reviews %}
      <div class="rev">
        <div class="mark2" aria-hidden="true">&ldquo;</div>
        <p>{{ r.text }}</p>
        <div class="who">{{ r.author or 'Verified customer' }}{% if r.source %}<small>via {{ r.source }}</small>{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ---------- OPENING HOURS ---------- #}
{% if hours %}
<section class="hours">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">Opening hours</p>
      <h2>When to find us</h2>
      <p class="lead">Pop in any time we're open — we'd love to see you.</p>
    </div>
    <div class="hours-card">
      {% for h in hours %}
      <div class="hours-row">
        <span class="day">{{ h.day }}</span>
        <span class="time">{{ h.time }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ---------- GOOD TO KNOW (only when researched) ---------- #}
{% if good_to_know %}
<section class="gtk">
  <div class="wrap">
    <p class="eyebrow">Good to know</p>
    <div class="gtk-wrap">
      {% for g in good_to_know %}<span class="gtk-chip">{{ g }}</span>{% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ---------- CTA BAND ---------- #}
<section class="cta-band">
  <div class="wrap">
    <div>
      <h2>{{ cta.heading }}</h2>
      <p>
        {%- if cta.kind == 'book' %}We'd love to see you at {{ biz.name }}{% if biz.city %} in {{ biz.city }}{% endif %}. Get in touch to lock in a time.
        {%- elif cta.kind == 'order' %}Tell us what you need and we'll take care of it.
        {%- elif cta.kind == 'visit' %}Come and say hello{% if biz.city %} in {{ biz.city }}{% endif %} — we'd love to have you in.
        {%- else %}Have a question or ready to get started? We're happy to help.{% endif %}
      </p>
    </div>
    <a class="btn btn-primary" href="{{ cta.href }}">{{ cta.label }} →</a>
  </div>
</section>

{# ---------- CONTACT / FIND US ---------- #}
<section class="contact" id="contact">
  <div class="wrap">
    <div class="sec-head">
      <p class="eyebrow">Find us</p>
      <h2>Come say hello</h2>
      <p class="lead">We'd love to welcome you to {{ biz.name }}{% if biz.city %} in {{ biz.city }}{% endif %}.</p>
    </div>
    <div class="contact-grid">
      <div class="info">
        {% if biz.address %}
        <div class="info-item">
          <div class="ic2" aria-hidden="true">📍</div>
          <div><div class="k">Address</div><div class="v">{{ biz.address }}</div></div>
        </div>
        {% endif %}
        {% if biz.phone %}
        <div class="info-item">
          <div class="ic2" aria-hidden="true">📞</div>
          <div><div class="k">Phone</div><div class="v"><a href="tel:{{ biz.phone }}">{{ biz.phone }}</a></div></div>
        </div>
        {% endif %}
        {% if biz.email %}
        <div class="info-item">
          <div class="ic2" aria-hidden="true">✉️</div>
          <div><div class="k">Email</div><div class="v"><a href="mailto:{{ biz.email }}">{{ biz.email }}</a></div></div>
        </div>
        {% endif %}
        {% if not biz.address and not biz.phone and not biz.email %}
        <div class="info-item">
          <div class="ic2" aria-hidden="true">👋</div>
          <div><div class="k">Say hello</div><div class="v">We're just around the corner{% if biz.city %} in {{ biz.city }}{% endif %} — drop by any time.</div></div>
        </div>
        {% endif %}

        {% if biz.instagram or biz.facebook %}
        <div class="socials">
          {% if biz.instagram %}
          <a class="social" href="{% if 'http' in biz.instagram %}{{ biz.instagram }}{% else %}https://instagram.com/{{ biz.instagram|replace('@','') }}{% endif %}" target="_blank" rel="noopener">📸 Instagram</a>
          {% endif %}
          {% if biz.facebook %}
          <a class="social" href="{% if 'http' in biz.facebook %}{{ biz.facebook }}{% else %}https://facebook.com/{{ biz.facebook }}{% endif %}" target="_blank" rel="noopener">👍 Facebook</a>
          {% endif %}
        </div>
        {% endif %}
      </div>

      <div class="map">
        <div class="pin" aria-hidden="true"></div>
        <a class="maplink" href="{{ map_url }}" target="_blank" rel="noopener">Open in maps →</a>
      </div>
    </div>
  </div>
</section>

{# ---------- FOOTER ---------- #}
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-brand">{{ biz.name }}</div>
        {% if biz.category or biz.city %}
        <div style="margin-top:6px;font-size:14px">{{ biz.category }}{% if biz.category and biz.city %} · {% endif %}{{ biz.city }}</div>
        {% endif %}
      </div>
      {% if biz.phone %}<a class="foot-cta" href="tel:{{ biz.phone }}">📞 Call {{ biz.name }}</a>{% else %}<a class="foot-cta" href="#contact">Get in touch →</a>{% endif %}
    </div>
    <div class="foot-meta">
      <span>© {{ year }} {{ biz.name }}. All rights reserved.</span>
      <span class="sample-badge"><span class="dot" aria-hidden="true"></span> Free sample site by {{ brand.name or 'Shiftora' }}</span>
    </div>
  </div>
</footer>

{# ---------- mobile sticky CTA ---------- #}
<div class="sticky-cta" id="stickyCta" role="complementary" aria-label="Contact shortcut">
  <div class="t">{{ biz.name }}<small>Get in touch today</small></div>
  {% if biz.phone %}<a href="tel:{{ biz.phone }}">Call now</a>{% else %}<a href="#contact">Contact</a>{% endif %}
</div>

<script>
  // Progressive enhancement only — the page is fully usable with JS disabled.
  (function(){
    var nav = document.getElementById('nav');
    var sticky = document.getElementById('stickyCta');
    var contact = document.getElementById('contact');
    function onScroll(){
      var y = window.pageYOffset || document.documentElement.scrollTop;
      if(nav){ nav.classList.toggle('scrolled', y > 8); }
      if(sticky){
        var nearContact = contact && contact.getBoundingClientRect().top < window.innerHeight * 0.85;
        sticky.classList.toggle('show', y > 480 && !nearContact);
      }
    }
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  })();
</script>

</body>
</html>
