<div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;color:#1d2433;font-size:16px;line-height:1.6;max-width:560px;margin:0 auto">
  <p>{{ greeting }}</p>

  <p>{{ intro }}</p>

  <p>{{ link_lead }}<br>
    <a href="{{ preview_url }}" style="color:#2a5db0;font-weight:600;word-break:break-all">{{ preview_url }}</a>
  </p>

  <p style="text-align:center;margin:26px 0">
    <a href="{{ preview_url }}"
       style="background:#2a5db0;color:#fff;padding:13px 26px;border-radius:8px;
              text-decoration:none;font-weight:700;display:inline-block">
      Open the sample website →
    </a>
  </p>

  <p>{{ price_line }}</p>

  <p>{{ cta_line }}</p>

  <p style="margin-top:22px">Cheers,<br>{{ founder }} / {{ brand.name }}</p>

  {{ footer_html | safe }}
</div>
