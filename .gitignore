# Secrets — NEVER commit these. Use GitHub Actions secrets instead.
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Local drafts written in review mode (contain prospect data; keep out of git)
outbox/*.eml
outbox/review_queue.csv
outbox/review_queue_legacy_*.csv
outbox/contact_list.csv
outbox/*.md
outbox/*.json

# Per-run summary / upgrade reports (internal working docs; keep local only)
RUN_*.md
UPGRADE_*.md

# Logs / scratch
*.log
runs/*.json
.DS_Store

# One-off batch tooling + research scratch for the upgrade run. The data files
# (osm pool, selected prospects, per-business enrichment) contain raw prospect
# emails, so this whole dir stays out of the public repo.
tools/

# NOTE: state/ and previews/ are intentionally NOT ignored.
#   state/    -> dedup + suppression lists must persist across runs (committed by the Action)
#   previews/ -> generated sample sites are served by GitHub Pages, so they must be committed
