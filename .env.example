# ============================================================================
#  SECRETS / CREDENTIALS  —  copy this file to ".env" and fill in what you have.
#  Everything here is OPTIONAL. With NONE of these set, the pipeline still runs
#  for free using OpenStreetMap and writes ready-to-send email drafts to outbox/.
#
#  In GitHub Actions, do NOT use this file — add each line as a repository
#  Secret instead (Settings -> Secrets and variables -> Actions).
# ============================================================================

# --- Email DISCOVERY + VERIFICATION (optional) ------------------------------
# Hunter.io free tier ~25-50 searches/mo. Used to find emails behind a domain
# and to verify deliverability before sending. Without it, the pipeline falls
# back to syntax + MX-record checks (free, no key).
HUNTER_API_KEY=

# --- B2B LEAD SOURCE: Apollo (optional) -------------------------------------
# Free tier has API access but limited credits. Leave blank to skip Apollo and
# rely on OpenStreetMap + the manual-CSV path (leads_manual.csv).
APOLLO_API_KEY=

# --- EMAIL SENDING (optional — only needed when SEND_MODE=auto) --------------
# Any standard SMTP works. Brevo free tier = 300 emails/day at no cost.
# Leave these blank to stay in "review" mode (drafts written to outbox/).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# The visible From address + name on outgoing mail.
FROM_EMAIL=info@shiftora.ai
FROM_NAME=Shiftora

# --- Overrides (optional) ---------------------------------------------------
# Flip to "auto" ONLY after you've read the compliance section in README.md
# and verified your sending domain (SPF/DKIM/DMARC). Default is "review".
SEND_MODE=review
